# ── Sai Lounge POS — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3001

# JWT Secret (change this to a long random string in production)
JWT_SECRET=sai_lounge_secret_2024

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ── Gmail OAuth2 (for automated email reports) ──────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
REFRESH_TOKEN=your_gmail_refresh_token
EMAIL_USER=youremail@gmail.com
REDIRECT_URI=https://developers.google.com/oauthplayground
